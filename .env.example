# Copy this file to `.env.local` and fill in real values. Never commit `.env.local`.

# --- Required (Supabase) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Optional: run SQL migrations locally (npm run db:migrate) — database password, NOT API keys ---
# From Supabase → Project Settings → Database. Or paste migrations/_bundle_all.sql (after npm run db:migrate:bundle) in SQL Editor.
# SUPABASE_DB_PASSWORD=
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# --- Site URL (used for Stripe redirects, emails, sitemap) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Social (optional overrides; defaults are printlyae / @printly.ae) ---
# NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://www.instagram.com/printlyae
# NEXT_PUBLIC_SOCIAL_TIKTOK=https://www.tiktok.com/@printly.ae

# --- Admin shipping label preview width (inches, 2–4; match LENVII roll / driver) ---
# NEXT_PUBLIC_LABEL_WIDTH_IN=4

# --- Stripe (omit STRIPE_SECRET_KEY to use legacy “Place order” without payment) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional: publishable key so the checkout page shows the Stripe / Apple Pay flow before the session API runs (pk_test_... / pk_live_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Email / cron (optional; app works without these for basic flows) ---
# SUPABASE_EDGE_FUNCTION_URL=
# ADMIN_EMAIL=
# ADMIN_EMAILS=
# CRON_SECRET=
