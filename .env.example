# Copy this file to `.env.local` and fill in real values. Never commit `.env.local`.

# --- Required (Supabase) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Site URL (used for Stripe redirects, emails, sitemap) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Stripe (optional: omit STRIPE_SECRET_KEY to use legacy checkout without Stripe) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email / cron (optional; app works without these for basic flows) ---
# SUPABASE_EDGE_FUNCTION_URL=
# ADMIN_EMAIL=
# ADMIN_EMAILS=
# CRON_SECRET=
