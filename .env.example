# Copy this file to `.env.local` and fill in real values. Never commit `.env.local`.

# --- Required (Supabase) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Site URL (used for Stripe redirects, emails, sitemap) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Stripe (omit STRIPE_SECRET_KEY to use legacy “Place order” without payment) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional: publishable key so the checkout page shows the Stripe / Apple Pay flow before the session API runs (pk_test_... / pk_live_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Email / cron (optional; app works without these for basic flows) ---
# SUPABASE_EDGE_FUNCTION_URL=
# ADMIN_EMAIL=
# ADMIN_EMAILS=
# CRON_SECRET=
